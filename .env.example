VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset

VITE_STK_PROXY_URL=https://your-vercel-domain/api/stkpush
VITE_AUTHOR_WHATSAPP_NUMBER=2547XXXXXXXX
VITE_ADMIN_EMAIL=admin@example.com
VITE_APP_API_BASE=

# Optional legacy browser socket config (not required for checkout)
VITE_API_BASE_URL=https://your-gateway-domain
VITE_XECO_SOCKET_NAMESPACE=/business
VITE_XECO_SOCKET_URL=https://your-gateway-domain/business
VITE_XECO_SOCKET_AUTH_KEY=your_socket_auth_key_optional
VITE_XECO_SERVICE_TYPE=payment

# Server-side Vercel function variables (set in Vercel project env, not exposed to browser)
XECOFLOW_BASE_URL=https://xecoflow.onrender.com
XECOFLOW_CONSUMER_KEY=ck_your_consumer_key_here
XECOFLOW_CONSUMER_SECRET=cs_your_consumer_secret_here
XECO_TOKEN_URL=https://xecoflow.onrender.com/api/v1/auth/token
XECO_GATEWAY_URL=https://xecoflow.onrender.com/api/v1/gateway
XECO_BUSINESS_SHORTCODE=your_business_shortcode
XECO_CALLBACK_URL=https://your-public-domain/api/webhook
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-admin-sdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=\"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n\"
XECO_WEBHOOK_TOKEN=optional_shared_secret
ADMIN_EMAIL=admin@example.com

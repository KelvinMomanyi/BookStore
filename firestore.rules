rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow admins to manage books
    match /books/{bookId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow public to create orders, but only owners/admins to read them
    match /orders/{orderId} {
      allow create: if true;
      allow read, update: if true; // Temporary allow for testing/payment updates via client
      allow delete: if request.auth != null;
    }
  }
}
